# .env.example — Template de variables de entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA commitees el archivo .env al repositorio

# ─────────────────────────────────────
#  SERVIDOR CENTRAL
# ─────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ─────────────────────────────────────
#  AGENTE
# ─────────────────────────────────────
AGENT_PORT=8001

# ─────────────────────────────────────
#  SEGURIDAD
# ─────────────────────────────────────
# Generá uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_DE_64_CARACTERES

# ─────────────────────────────────────
#  BASE DE DATOS
# ─────────────────────────────────────
# Ruta a la base de datos SQLite. Por defecto, en la carpeta servidor/
DATABASE_PATH=./monitor.db

# ─────────────────────────────────────
#  HEARTBEAT
# ─────────────────────────────────────
# Intervalo de verificación de PCs en segundos (default: 15)
HEARTBEAT_INTERVAL=15
# Timeout de conexión al agente en segundos (default: 5)
AGENT_TIMEOUT=5

# ─────────────────────────────────────
#  NOTIFICACIONES (opcional)
# ─────────────────────────────────────
# Habilitar notificaciones de escritorio Windows
DESKTOP_NOTIFICATIONS=true

# ─────────────────────────────────────
#  ACTIVE DIRECTORY (enterprise — futuro)
# ─────────────────────────────────────
# AD_DOMAIN=empresa.local
# AD_SERVER=dc01.empresa.local
# AD_BASE_DN=DC=empresa,DC=local
# AD_ADMIN_GROUP=CN=IT-Admins,OU=Groups,DC=empresa,DC=local

# ─────────────────────────────────────
#  MODO DE ENTORNO
# ─────────────────────────────────────
# development | production
ENVIRONMENT=development

# ─────────────────────────────────────
#  LOGS
# ─────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=./logs/monitor.log
