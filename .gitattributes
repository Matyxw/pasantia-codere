# Normalize line endings to LF in the repo, but checkout CRLF on Windows
* text=auto eol=lf

# Windows batch files MUST be CRLF or they break
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — never diff these
*.db binary
*.sqlite binary
*.sqlite3 binary
*.xlsx binary
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
*.ttf binary
*.exe binary
*.whl binary

# Python source — always LF
*.py linguist-language=Python
*.pyi linguist-language=Python

# Mark generated files so GitHub won't show them in diffs
dashboard/dist/** linguist-generated=true
dashboard/node_modules/** linguist-vendored=true
