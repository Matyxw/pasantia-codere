root = true

# ── Global ─────────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# ── Python ─────────────────────────────────────────────────────────────────────
[*.py]
indent_size = 4

# ── JavaScript / JSX / TypeScript ──────────────────────────────────────────────
[*.{js,jsx,ts,tsx}]
indent_size = 2

# ── Web ────────────────────────────────────────────────────────────────────────
[*.{css,html,json,yaml,yml,toml,md}]
indent_size = 2

# ── Windows Batch — CRLF obligatorio ──────────────────────────────────────────
[*.{bat,cmd}]
end_of_line = crlf
indent_size = 4

# ── PowerShell ─────────────────────────────────────────────────────────────────
[*.ps1]
end_of_line = crlf
indent_size = 4

# ── Makefiles — TABS obligatorios ──────────────────────────────────────────────
[Makefile]
indent_style = tab
